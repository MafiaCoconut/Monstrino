# Model configuration
MODEL_DIR=./models
DEVICE=auto
# auto, cpu, cuda, or rocm

# Model cache
HF_HOME=./cache/huggingface
TORCH_HOME=./cache/torch

# API configuration
MAX_IMAGE_SIZE=2048
DEFAULT_MODE=best
# best, largest, or all

# Detection thresholds
BOX_THRESHOLD=0.25
TEXT_THRESHOLD=0.20

# Mask postprocessing
MIN_MASK_AREA=100
FEATHER_RADIUS=3
FILL_HOLES=true

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Logging
LOG_LEVEL=INFO
# DEBUG, INFO, WARNING, ERROR
